{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "eslint/no-unused-vars": "error",
    "no-console": "warn"
  },
  "ignorePatterns": [".next/", "node_modules/", "dist/", "coverage/"]
}
